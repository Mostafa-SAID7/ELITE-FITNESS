# Git line ending normalization
# Auto detect text files and normalize line endings to LF
* text=auto

# Source files
*.ts text eol=lf
*.js text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.eot binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary
*.zip binary
*.tar.gz binary
*.tgz binary

# Git files
.gitignore merge=union
.gitattributes merge=union
